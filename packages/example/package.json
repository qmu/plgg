{
  "name": "@plgg/example",
  "version": "0.0.2",
  "private": true,
  "description": "A To-Do app demo for the plgg monorepo — one Elm-Architecture program (Model/update/view) rendered both server-side (SSR via plgg-server) and client-side (CSR via plgg-view's runtime).",
  "scripts": {
    "build": "vite build",
    "test": "tsc --noEmit && plgg-test src",
    "tsc": "tsc --noEmit",
    "tsc:watch": "tsc --noEmit --watch",
    "test:watch": "plgg-test src --watch",
    "coverage": "tsc --noEmit && plgg-test src --coverage",
    "coverage:watch": "plgg-test src --coverage --watch",
    "serve": "vite",
    "serve:ssr": "tsx src/server.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/qmu/plgg.git"
  },
  "author": "qmu",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/qmu/plgg/issues"
  },
  "homepage": "https://github.com/qmu/plgg#readme",
  "dependencies": {
    "plgg": "file:../plgg",
    "plgg-view": "file:../plgg-view",
    "plgg-router": "file:../plgg-router",
    "plgg-server": "file:../plgg-server"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "happy-dom": "^15.0.0",
    "plgg-test": "file:../plgg-test",
    "tsx": "^4.0.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.10"
  }
}
