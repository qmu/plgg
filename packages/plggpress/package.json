{
  "name": "plggpress",
  "version": "0.0.1",
  "description": "A reusable VitePress-like static-site generator built from scratch on the plgg family: a typed SiteConfig contract (IA + home data), a single base-path href resolver, and a config-loading CLI.",
  "type": "module",
  "files": [
    "dist",
    "src",
    "bin"
  ],
  "bin": {
    "plggpress": "bin/plggpress.mjs"
  },
  "main": "dist/index.es.js",
  "module": "dist/index.es.js",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.es.js"
      }
    }
  },
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "plgg-bundle",
    "test": "tsc --noEmit && plgg-test src",
    "tsc": "tsc --noEmit",
    "tsc:watch": "tsc --noEmit --watch",
    "test:watch": "plgg-test src --watch",
    "coverage": "tsc --noEmit && plgg-test src --coverage",
    "coverage:watch": "plgg-test src --coverage --watch"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/qmu/plgg.git"
  },
  "author": "qmu",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/qmu/plgg/issues"
  },
  "homepage": "https://github.com/qmu/plgg#readme",
  "dependencies": {
    "plgg": "file:../plgg",
    "plgg-http": "file:../plgg-http",
    "plgg-server": "file:../plgg-server",
    "plgg-view": "file:../plgg-view",
    "plgg-md": "file:../plgg-md",
    "plgg-highlight": "file:../plgg-highlight",
    "plgg-cli": "file:../plgg-cli",
    "plggmatic": "file:../plggmatic",
    "plgg-content": "file:../plgg-content",
    "plgg-sql": "file:../plgg-sql"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "plgg-bundle": "file:../plgg-bundle",
    "plgg-test": "file:../plgg-test",
    "typescript": "^6.0.3"
  }
}
