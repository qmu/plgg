{
  "name": "plgg-poc-portal",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "The plggpress PoC portal — a static index app listing every plggpress confidence-collection PoC (its technical question, confidence signal, status, and verdict) with the *.qmu.dev hostname/port map of the fleet.",
  "scripts": {
    "build": "node src/entrypoints/build.ts",
    "test": "tsc --noEmit && plgg-test src",
    "tsc": "tsc --noEmit",
    "tsc:watch": "tsc --noEmit --watch",
    "test:watch": "plgg-test src --watch",
    "coverage": "tsc --noEmit && plgg-test src --coverage",
    "serve": "node src/entrypoints/serve.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/qmu/plgg.git"
  },
  "author": "qmu",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/qmu/plgg/issues"
  },
  "homepage": "https://github.com/qmu/plgg#readme",
  "dependencies": {
    "plgg": "file:../plgg",
    "plgg-view": "file:../plgg-view",
    "plgg-server": "file:../plgg-server"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "plgg-test": "file:../plgg-test",
    "typescript": "^6.0.3"
  }
}
