{
  "$schema": "https://typedoc.org/schema.json",
  "plugin": ["typedoc-plugin-markdown"],
  "readme": "none",
  "githubPages": false,
  "excludeInternal": true,
  "excludePrivate": true,
  "hideBreadcrumbs": true,
  "useCodeBlocks": true,
  "disableSources": true,
  "parametersFormat": "list",
  "indexFormat": "list",
  "outputFileStrategy": "modules",
  "exclude": [
    "**/Grammaticals/**",
    "**/Abstracts/**"
  ]
}
