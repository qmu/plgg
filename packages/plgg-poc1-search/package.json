{
  "name": "plgg-poc1-search",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "PoC 1 of the plggpress confidence-collection fleet: browser-side indexed full-text search vs vector RAG, measured side-by-side on the plgg guide corpus (index size, build time, query latency, answer quality).",
  "scripts": {
    "build": "npm run build:app && npm run build:index",
    "build:index": "node src/entrypoints/buildIndex.ts",
    "build:app": "plgg-bundle",
    "test": "tsc --noEmit && plgg-test src",
    "tsc": "tsc --noEmit",
    "tsc:watch": "tsc --noEmit --watch",
    "test:watch": "plgg-test src --watch",
    "coverage": "tsc --noEmit && plgg-test src --coverage",
    "serve": "node src/entrypoints/serve.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/qmu/plgg.git"
  },
  "author": "qmu",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/qmu/plgg/issues"
  },
  "homepage": "https://github.com/qmu/plgg#readme",
  "dependencies": {
    "plgg": "file:../plgg",
    "plgg-view": "file:../plgg-view",
    "plgg-router": "file:../plgg-router"
  },
  "devDependencies": {
    "@huggingface/transformers": "^3.5.1",
    "@types/node": "^25.6.0",
    "plgg-bundle": "file:../plgg-bundle",
    "plgg-test": "file:../plgg-test",
    "typescript": "^6.0.3"
  }
}
