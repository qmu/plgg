{
  "name": "plgg-server",
  "version": "0.0.2",
  "description": "Server-side HTTP router, handler, and view layer built from scratch on the plgg framework",
  "main": "dist/index.cjs.js",
  "module": "dist/index.es.js",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.es.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs.js"
      }
    },
    "./node": {
      "import": {
        "types": "./dist/node.d.ts",
        "default": "./dist/node.es.js"
      },
      "require": {
        "types": "./dist/node.d.ts",
        "default": "./dist/node.cjs.js"
      }
    },
    "./bun": {
      "import": {
        "types": "./dist/bun.d.ts",
        "default": "./dist/bun.es.js"
      },
      "require": {
        "types": "./dist/bun.d.ts",
        "default": "./dist/bun.cjs.js"
      }
    },
    "./deno": {
      "import": {
        "types": "./dist/deno.d.ts",
        "default": "./dist/deno.es.js"
      },
      "require": {
        "types": "./dist/deno.d.ts",
        "default": "./dist/deno.cjs.js"
      }
    },
    "./ssg": {
      "import": {
        "types": "./dist/ssgEntry.d.ts",
        "default": "./dist/ssgEntry.es.js"
      },
      "require": {
        "types": "./dist/ssgEntry.d.ts",
        "default": "./dist/ssgEntry.cjs.js"
      }
    }
  },
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "vite build",
    "test": "tsc --noEmit && plgg-test src",
    "tsc": "tsc --noEmit",
    "tsc:watch": "tsc --noEmit --watch",
    "test:watch": "plgg-test src --watch",
    "coverage": "tsc --noEmit && plgg-test src --coverage",
    "coverage:watch": "plgg-test src --coverage --watch",
    "publish": "vite build && npm publish"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/qmu/plgg.git"
  },
  "author": "qmu",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/qmu/plgg/issues"
  },
  "homepage": "https://github.com/qmu/plgg#readme",
  "dependencies": {
    "plgg": "file:../plgg",
    "plgg-http": "file:../plgg-http",
    "plgg-view": "file:../plgg-view"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "happy-dom": "^15.0.0",
    "plgg-test": "file:../plgg-test",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vite-plugin-dts": "^5.0.0"
  }
}
