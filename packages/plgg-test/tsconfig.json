{
  "compilerOptions": {
    /* Compiler Option */
    "target": "ES2021",
    /* plgg-test runs its `.ts` directly via Node's native
       type-stripping (ESM), and uses `import.meta.url` to locate
       fixtures. ESNext + Bundler resolution lets the source use the
       repo's extensionless self-alias specifiers (`plgg-test/Core/…`)
       while still emitting/treating modules as ESM — without forcing
       `.js` suffixes everywhere that NodeNext+type:module would. */
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "paths": {
      "plgg-test/*": ["./src/*"]
    },
    "rootDir": "src",
    "outDir": "dist",
    "types": ["node"],
    /* Type Checking Rules */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "allowUnusedLabels": false,
    "allowUnreachableCode": false,
    "forceConsistentCasingInFileNames": true,
    "exactOptionalPropertyTypes": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "allowJs": false
  },
  "include": ["src/**/*"]
}
