{
  /* Declaration-emit config for the library build (the in-house bundler).
     The base tsconfig.json is type-check only; this build config narrows to
     src/** and turns emit back on so .d.ts files land under dist/. */
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "rootDir": "src",
    "outDir": "dist"
  },
  "include": [
    "src/**/*"
  ]
}
