{
  "name": "plgg-search",
  "version": "0.0.1",
  "files": [
    "dist"
  ],
  "description": "The browser-shippable full-text search core of the plgg family, ported from the proven PoC 1 artifact: a shared latin+CJK tokenizer (Intl.Segmenter word mode or bigram fallback, carried inside the index so index/query strategy cannot mismatch), a heading-scoped markdown chunker, an inverted-index builder, and from-scratch BM25 ranking. Zero dependencies beyond plgg; no node builtins - the same code runs in the SSG build step and in the reader's browser.",
  "main": "dist/index.cjs.js",
  "module": "dist/index.es.js",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.es.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs.js"
      }
    }
  },
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "plgg-bundle",
    "test": "tsc --noEmit && plgg-test src",
    "tsc": "tsc --noEmit",
    "tsc:watch": "tsc --noEmit --watch",
    "test:watch": "plgg-test src --watch",
    "coverage": "tsc --noEmit && plgg-test src --coverage",
    "coverage:watch": "plgg-test src --coverage --watch"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/qmu/plgg.git"
  },
  "author": "qmu",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/qmu/plgg/issues"
  },
  "homepage": "https://github.com/qmu/plgg#readme",
  "dependencies": {
    "plgg": "file:../plgg"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "plgg-bundle": "file:../plgg-bundle",
    "plgg-test": "file:../plgg-test",
    "typescript": "^6.0.3"
  }
}
