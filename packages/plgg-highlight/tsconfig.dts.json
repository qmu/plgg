{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "declaration": true,
    "emitDeclarationOnly": true,
    "outDir": "dist.stage",
    "incremental": false,
    "composite": false
  },
  "exclude": [
    "**/*.spec.ts",
    "**/*.spec.tsx",
    "dist",
    "dist.stage",
    "node_modules"
  ]
}