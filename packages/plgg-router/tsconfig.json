{
  "compilerOptions": {
    /* Compiler Option */
    "target": "ES2021",
    "module": "NodeNext",
    "lib": [
      "ES2021",
      "DOM",
      "DOM.Iterable"
    ],
    "types": [
      "node"
    ],
    "noEmit": true,
    "paths": {
      "plgg-router*": [
        "./src/*"
      ]
    },
    /* JSX: route handlers return `VNode`, and specs/example author trees with
       JSX, processed by the plgg-view runtime. The library sources stay plain
       `.ts` (they operate on `VNode`); only the `.tsx` files use the runtime. */
    "jsx": "react-jsx",
    "jsxImportSource": "plgg-view",
    /* Type Checking Rules */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "allowUnusedLabels": false,
    "allowUnreachableCode": false,
    "forceConsistentCasingInFileNames": true,
    "exactOptionalPropertyTypes": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "allowJs": false,
    "erasableSyntaxOnly": true
  },
  "include": [
    "src/**/*",
    "example.ts"
  ]
}
