{
  "name": "plgg-view",
  "version": "0.0.1",
  "description": "A minimal Elm Architecture (TEA) for the browser built from scratch on the plgg framework: a typed Html<Msg> view tree, pure sandbox/application runtimes, and SSR renderToString",
  "main": "dist/index.cjs.js",
  "module": "dist/index.es.js",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.es.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs.js"
      }
    },
    "./client": {
      "import": {
        "types": "./dist/client.d.ts",
        "default": "./dist/client.es.js"
      },
      "require": {
        "types": "./dist/client.d.ts",
        "default": "./dist/client.cjs.js"
      }
    },
    "./style": {
      "import": {
        "types": "./dist/styleEntry.d.ts",
        "default": "./dist/styleEntry.es.js"
      },
      "require": {
        "types": "./dist/styleEntry.d.ts",
        "default": "./dist/styleEntry.cjs.js"
      }
    }
  },
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "plgg-bundle",
    "test": "tsc --noEmit && plgg-test src",
    "tsc": "tsc --noEmit",
    "tsc:watch": "tsc --noEmit --watch",
    "test:watch": "plgg-test src --watch",
    "coverage": "tsc --noEmit && plgg-test src --coverage",
    "coverage:watch": "plgg-test src --coverage --watch",
    "publish": "npm run build && npm publish"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/qmu/plgg.git"
  },
  "author": "qmu",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/qmu/plgg/issues"
  },
  "homepage": "https://github.com/qmu/plgg#readme",
  "dependencies": {
    "plgg": "file:../plgg"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "happy-dom": "^15.0.0",
    "plgg-bundle": "file:../plgg-bundle",
    "plgg-test": "file:../plgg-test",
    "typescript": "^6.0.3"
  }
}
