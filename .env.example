# Copy to `.env` (git-ignored) at the REPOSITORY ROOT — the single home for
# development credentials. scripts/serve-poc.sh sources it (exported) before
# compose interpolation, so every workloads/*/compose.yaml `${VAR:-}`
# passthrough sees these values; a variable already set in your shell wins
# over the file. Keep lines as plain KEY=value — no quotes, no $expansion.
#
# Worktree protocol: when a new worktree is created under .worktrees/, the
# root repository's .env is copied into it, so parallel worktrees start with
# working credentials.

# OpenAI standing key for the Realtime PoCs (poc3-voice, poc4-edit): the
# serve process mints SHORT-LIVED session keys from it; it never reaches a
# browser or the repo.
OPENAI_API_KEY=
