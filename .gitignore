**/dist.old/
**/coverage/

# Git worktrees (created under the repo per the workaholic/trippin convention)
.worktrees/

# Environment files
.env
.env.*
!.env.example

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.local
**/.claude/settings.local.json
