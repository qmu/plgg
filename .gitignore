# Node modules and logs
node_modules/
**/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Publish preflight scratch: the publish-set dirs scripts/publish.ts writes for
# publish-npm.sh to consume (normally removed within the run).
.publish-set.*

# Same-session green gate stamp: check-all.sh writes it on a fully green run
# (a tracked working-tree digest); publish-npm.sh auto-skips its gate when the
# stamp still matches the tree, so SKIP_GATE need not be remembered.
.check-all-green.stamp

# Build outputs
**/dist/
# Transient staging/backup dirs from plgg-bundle's atomic dist publish
# (normally renamed/removed within a build; only linger if one is killed).
**/dist.stage/
**/dist.old/
**/coverage/

# Git worktrees (created under the repo per the workaholic/trippin convention)
.worktrees/

# Environment files
.env
.env.*
!.env.example

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.local
**/.claude/settings.local.json

# Playwright MCP session output (screenshots, snapshots, console logs)
.playwright-mcp/
**/.playwright-mcp/
