{
  "name": "@plgg/example",
  "version": "0.0.2",
  "private": true,
  "description": "Examples for the plgg monorepo: a full-stack demo over plgg-view, plgg-sql, plgg-server (SSR/CSR), and plgg-fetch",
  "scripts": {
    "build": "vite build",
    "test": "tsc --noEmit && vitest --run",
    "tsc": "tsc --noEmit",
    "tsc:watch": "tsc --noEmit --watch",
    "test:watch": "vitest",
    "coverage": "vitest --run --coverage",
    "coverage:watch": "vitest --coverage",
    "serve": "tsx src/ssr/server.ts",
    "client": "tsx src/client/main.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/qmu/plgg.git"
  },
  "author": "qmu",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/qmu/plgg/issues"
  },
  "homepage": "https://github.com/qmu/plgg#readme",
  "dependencies": {
    "plgg": "file:../plgg",
    "plgg-view": "file:../plgg-view",
    "plgg-server": "file:../plgg-server",
    "plgg-fetch": "file:../plgg-fetch",
    "plgg-sql": "file:../plgg-sql"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.5",
    "happy-dom": "^15.0.0",
    "tsx": "^4.0.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  }
}
